# Core runtime
# Use the public HTTPS origin actually opened by users. No trailing slash.
PORT=4000
VITE_API_BASE_URL=http://localhost:4000
PUBLIC_APP_URL=https://app.example.com
SESSION_SECRET=replace-with-a-long-random-secret

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# PyMD short links
# Required if you want externally shortened webinar and payment links.
PYMD_API_KEY=your_pymd_api_key
# Optional custom short-link domain configured in PyMD.
PYMD_DOMAIN=

# AiSensy
# Preferred variable name is AISSENSY_API_KEY. The server also accepts AISENSY_API_KEY.
AISSENSY_API_KEY=your_aisensy_api_key
AISSENSY_PAYMENT_LINK_CAMPAIGN=payment_link_onboarding_2
AISSENSY_WEBHOOK_URL=https://funnels.example.com/webhook/aisensy

# LiveKit webinar transport
# Keep the existing hosted transport here for the default app mode.
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Notes:
# - Production hosting should keep frontend, API, Socket.IO, payment pages, and webinar pages on the same origin.
# - The current frontend does not use VITE_SIGNALING_* variables even though older docs mention them.
# - PUBLIC_APP_URL is important for public short-link generation.
