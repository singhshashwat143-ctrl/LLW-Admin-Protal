# Local development:
# `npm run dev` starts Vite on http://localhost:5173 and the webinar server on http://localhost:8080.
# Vite proxies /health, /ws, /api/ws, and /socket.io so the app can connect through one localhost origin.

# Optional server port for deployed Node host
PORT=8080

# Razorpay checkout credentials
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Optional overrides when frontend and signaling are NOT same origin.
# Keep these empty for same-domain deploy.
# VITE_SIGNALING_WS_URL=wss://your-domain.com/ws
# VITE_SIGNALING_HTTP_URL=https://your-domain.com
# VITE_SIGNALING_IO_URL=https://your-domain.com

# Build frontend first, then run one integrated service:
# npm run build
# node server/webinar-server.mjs
