# Container runtime
PORT=8080
PUBLIC_APP_URL=https://app.example.com
SESSION_SECRET=replace-with-a-long-random-secret

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# PyMD short links
PYMD_API_KEY=your_pymd_api_key
PYMD_DOMAIN=

# AiSensy
AISSENSY_API_KEY=your_aisensy_api_key
AISSENSY_PAYMENT_LINK_CAMPAIGN=payment_link_onboarding_2
AISSENSY_WEBHOOK_URL=https://funnels.example.com/webhook/aisensy

# LiveKit webinar transport
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
